# Server-side only — used by the API route to authenticate with GitHub.
# Never exposed to the browser.
GITHUB_PAT=
GITHUB_OWNER=
GITHUB_REPO=

# How long (seconds) to cache the GitHub API response server-side.
# All concurrent users share one cached fetch — GitHub is only called
# once per window. Defaults to 60. Increase on large teams to stay
# well within GitHub's 5000 req/hr rate limit.
CACHE_TTL_SECONDS=60

# Optional: your Linear workspace slug (e.g. "acme" from linear.app/acme/...)
# If set, LL-#### patterns in PR titles become clickable Linear issue links.
NEXT_PUBLIC_LINEAR_SLUG=
